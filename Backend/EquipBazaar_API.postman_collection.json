          "name": "Update App Setting",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"key\": \"siteName\",\n  \"value\": \"EquipBazaar\"\n}" },
            "url": { "raw": "{{baseUrl}}/settings/app", "path": ["settings", "app"] }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "authToken", "value": "" }
  ]
