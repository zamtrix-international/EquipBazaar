    {
      "name": "Settings (Admin)",
      "item": [
        {
          "name": "Get Payment Gateway Config",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/settings/payment-gateway", "path": ["settings", "payment-gateway"] }
          }
        },
        {
          "name": "Update Payment Gateway Config",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
